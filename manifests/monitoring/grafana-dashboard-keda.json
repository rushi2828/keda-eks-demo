{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "KEDA on EKS — Full observability: scaling decisions, queue depth, throughput, logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔵 KEDA Scaling Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current number of running consumer pods managed by KEDA",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": 0 },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 18 }
            ]
          },
          "unit": "short",
          "mappings": [
            { "options": { "0": { "text": "SCALED TO ZERO" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Consumer Pods (Replicas)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{deployment=\"consumer\", namespace=\"keda-demo\"}",
          "legendFormat": "replicas"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SQS queue depth as seen by KEDA scaler",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "SQS Queue Depth",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "keda_scaler_metrics_value{namespace=\"keda-demo\", scaledObject=\"consumer-scaledobject\"}",
          "legendFormat": "queue depth"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "1 = KEDA is actively scaling, 0 = idle (scaled to zero)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "IDLE" }, "1": { "text": "ACTIVE" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "KEDA Scaler State",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "keda_scaler_active{namespace=\"keda-demo\", scaledObject=\"consumer-scaledobject\"}",
          "legendFormat": "active"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Messages processed per second across all consumer pods",
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Throughput (msg/s)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(messages_processed_total{namespace=\"keda-demo\"}[1m]))",
          "legendFormat": "processed/s"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Time series: queue depth vs number of consumer pods — shows KEDA scaling in action",
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Consumer Pods" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Queue Depth" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queue Depth vs Consumer Pods (KEDA Scaling Timeline)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "keda_scaler_metrics_value{namespace=\"keda-demo\", scaledObject=\"consumer-scaledobject\"}",
          "legendFormat": "Queue Depth"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{deployment=\"consumer\", namespace=\"keda-demo\"}",
          "legendFormat": "Consumer Pods"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 101,
      "title": "🟢 Application Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate of messages sent by producer vs processed by consumer",
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Sent" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Processed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "title": "Message Rate: Producer vs Consumer",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(messages_sent_total{namespace=\"keda-demo\"}[1m]))",
          "legendFormat": "Sent"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(messages_processed_total{namespace=\"keda-demo\"}[1m]))",
          "legendFormat": "Processed"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(processing_errors_total{namespace=\"keda-demo\"}[1m]))",
          "legendFormat": "Errors"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p50/p95/p99 message processing time in seconds",
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "title": "Processing Latency (p50 / p95 / p99)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(processing_duration_seconds_bucket{namespace=\"keda-demo\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(processing_duration_seconds_bucket{namespace=\"keda-demo\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(processing_duration_seconds_bucket{namespace=\"keda-demo\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 102,
      "title": "🟡 OpenTelemetry Collector Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "id": 8,
      "title": "OTel Collector — Spans Received/Exported",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(otelcol_receiver_accepted_spans[1m])",
          "legendFormat": "accepted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(otelcol_exporter_sent_spans[1m])",
          "legendFormat": "exported"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(otelcol_receiver_refused_spans[1m])",
          "legendFormat": "refused"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "id": 9,
      "title": "OTel Collector Memory Usage",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "otelcol_process_memory_rss",
          "legendFormat": "RSS"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 103,
      "title": "🔴 Live Logs (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Live structured logs from consumer pods — filter by job_id or level",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 34 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "wrapLogMessage": false
      },
      "title": "Consumer Logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=\"keda-demo\", app=\"consumer\"} | json",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "KEDA operator scaling decisions and errors",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 34 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true
      },
      "title": "KEDA Operator Logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=\"keda\", app=\"keda-operator\"}",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "type": "logs"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["keda", "eks", "sqs", "autoscaling", "loki", "otel"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "KEDA on EKS — Autoscaling Observability",
  "uid": "keda-eks-demo-v1",
  "version": 1
}
